{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "includeCoAuthoredBy": true,
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh repo view:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Read(**/*.md)",
      "Read(scripts/**)",
      "Read(docs/**)",
      "Read(.github/**)"
    ],
    "deny": [],
    "ask": [
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)"
    ]
  }
}
